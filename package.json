{
  "name": "codedeck-bridge",
  "displayName": "Codedeck Bridge",
  "description": "Bridge Claude Code sessions to Codedeck mobile app over Nostr relays",
  "version": "2026.6.171",
  "publisher": "halfzwarelinda",
  "repository": {
    "type": "git",
    "url": "https://github.com/HalfzwareLinda/codedeck-bridge-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codedeck.quickMenu",
        "title": "Codedeck: Quick Menu"
      },
      {
        "command": "codedeck.pair",
        "title": "Codedeck: Pair Phone"
      },
      {
        "command": "codedeck.status",
        "title": "Codedeck: Show Status"
      },
      {
        "command": "codedeck.disconnect",
        "title": "Codedeck: Disconnect All"
      }
    ],
    "configuration": {
      "title": "Codedeck Bridge",
      "properties": {
        "codedeck.relays": {
          "type": "array",
          "default": [
            "wss://relay.primal.net",
            "wss://relay.nostr.band",
            "wss://nos.lol"
          ],
          "description": "Nostr relay URLs for phone communication"
        },
        "codedeck.machineName": {
          "type": "string",
          "default": "",
          "description": "Display name for this machine (defaults to hostname)"
        },
        "codedeck.relayRegisterEndpoint": {
          "type": "string",
          "default": "",
          "description": "Optional admin endpoint to auto-register a paired phone's pubkey on a write-restricted private relay (e.g. https://relay2.descendant.io/api/register-agent). Leave empty if all your relays accept open writes. Pair the phone over an open relay in 'codedeck.relays'; once registered here it can also use the private relay for high-frequency session traffic."
        },
        "codedeck.relayRegisterToken": {
          "type": "string",
          "default": "",
          "description": "Bearer admin token for codedeck.relayRegisterEndpoint. Stored in VSCode settings — use a per-relay admin token, not a personal secret."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:@anthropic-ai/claude-agent-sdk --format=cjs --platform=node --target=node18 --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:@anthropic-ai/claude-agent-sdk --format=cjs --platform=node --target=node18 --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.2",
    "nostr-tools": "^2.23.1",
    "qrcode-svg": "^1.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  }
}
